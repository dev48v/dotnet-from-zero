@*
    STEP 7 — Shared layout for every Razor page.
    Razor turns the @{...} blocks and @Page directives in child
    pages into HTML; this file wraps that HTML with the navbar,
    footer, and CSS/JS includes that we want everywhere.

    The space theme is loaded from /css/site.css; we drop Bootstrap
    only for the grid because the rest of the styling is hand-rolled
    (small enough to read in one sitting).
*@
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Space Explorer</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap-grid.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <div class="topbar-inner">
            <a class="brand" asp-page="/Index">
                <span class="brand-mark">◉</span> Space&nbsp;Explorer
            </a>
            <nav class="primary-nav">
                <a asp-page="/Index">Today</a>
                <a asp-page="/Random">Random</a>
                <a asp-page="/History">History</a>
                <a asp-page="/Favourites">Favourites</a>
                <a href="/swagger" target="_blank">API</a>
            </nav>
        </div>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <footer class="footer">
        <span>Powered by NASA APOD · built with ASP.NET Core 8 + Razor Pages</span>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
